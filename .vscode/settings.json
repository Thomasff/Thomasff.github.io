{
  "markdown.copyFiles.destination": {
    "content/post/**/index.md": "${documentDirName}/${fileName}"
  },
  "markdown.copyFiles.overwriteBehavior": "nameIncrementally",  //同名则递增编号
  "markdown.copyFiles.generatePageRelativeMarkdownLinks": "always",
  "markdown.editor.filePaste.copyIntoWorkspace": "always"
}
